<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Camera access for biofield analysis -->
  <key>com.apple.security.device.camera</key>
  <true/>
  <!-- Microphone access for audio entrainment -->
  <key>com.apple.security.device.microphone</key>
  <true/>
  <!-- Outgoing network for Supabase, Discord OAuth, backend API -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Incoming network for local backend server (localhost:8000) -->
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- File read/write for exports (PDF, CSV, screenshots) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
