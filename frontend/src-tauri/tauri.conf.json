{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Biofield Mirror",
  "version": "0.2.1",
  "identifier": "com.biofield.mirror",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Biofield Mirror",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "./Entitlements.plist"
    }
  }
}
