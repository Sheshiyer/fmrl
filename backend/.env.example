# PIP Analysis Backend Environment Variables

# Server
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://pip:pip@localhost:5432/pip_analysis
DATABASE_ECHO=false
BIOFIELD_PERSISTENCE_ENABLED=false
BIOFIELD_SCORE_RECIPE_VERSION=v1
BIOFIELD_METRIC_RECIPE_VERSION=v1

# Redis
REDIS_URL=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
